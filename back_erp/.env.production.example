# ══════════════════════════════════════════
# ⚠️  Production Settings — انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════
APP_NAME="CodeSphere ERP"
APP_ENV=production
APP_KEY=          # شغّل: php artisan key:generate
APP_DEBUG=false   # ⚠️  مهم جداً - false في production
APP_URL=https://your-domain.com

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=codesphere_erp
DB_USERNAME=      # غيّر اليوزر
DB_PASSWORD=      # كلمة مرور قوية

FRONTEND_URL=https://your-frontend-domain.com
SANCTUM_STATEFUL_DOMAINS=your-frontend-domain.com

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true   # true في production
SESSION_DOMAIN=.your-domain.com

QUEUE_CONNECTION=redis  # redis أفضل من sync في production
CACHE_STORE=redis

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Paymob
PAYMOB_API_KEY=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=

IP_WHITELIST_ENABLED=false
