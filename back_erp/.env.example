APP_NAME="CodeSphere ERP"
APP_ENV=local
APP_KEY=base64:AdDCpOFsinPcAZ76wRRUTrojPP0sxGt+V+M2ZquOqzo=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ══════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=codesphere_erp
DB_USERNAME=root
DB_PASSWORD=

# ══════════════════════════════════════════
# SANCTUM & CORS - مهم جداً للـ Next.js
# ══════════════════════════════════════════
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# ══════════════════════════════════════════
# SESSION - لازم cookie مش database
# ══════════════════════════════════════════
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# ══════════════════════════════════════════
# CACHE & QUEUE
# ══════════════════════════════════════════
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

# ══════════════════════════════════════════
# MAIL
# ══════════════════════════════════════════
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@codesphere.io"
MAIL_FROM_NAME="${APP_NAME}"

# ══════════════════════════════════════════
# AWS (اختياري)
# ══════════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# ══════════════════════════════════════════
# SMS INTEGRATION (Twilio / Vonage)
# ══════════════════════════════════════════
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# ══════════════════════════════════════════
# PAYMENT GATEWAYS
# ══════════════════════════════════════════
PAYMOB_API_KEY=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ══════════════════════════════════════════
# EMAIL INBOX - IMAP (Gmail / Outlook)
# ══════════════════════════════════════════
# Gmail: imap.gmail.com:993 (SSL) - Use App Password
# Outlook: outlook.office365.com:993 (SSL)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_ENCRYPTION=ssl

# ══════════════════════════════════════════
# SECURITY
# ══════════════════════════════════════════
IP_WHITELIST_ENABLED=false

# ══════════════════════════════════════════
# GOOGLE MAPS (GPS Tracking)
# ══════════════════════════════════════════
GOOGLE_MAPS_API_KEY=

# ══════════════════════════════════════════
# CLOUD STORAGE
# ══════════════════════════════════════════
CLOUD_STORAGE_PROVIDER=local
# AWS S3 - already configured above
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=

